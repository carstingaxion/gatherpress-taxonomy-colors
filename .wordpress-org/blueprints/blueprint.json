{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/wp-admin/post.php?post=10&action=edit",
	"preferredVersions": {
		"php": "8.3",
		"wp": "latest"
	},
	"login": true,
	"steps": [
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "GatherPress Taxonomy Colors",
        "blogdescription": "Enhancing GatherPress with Taxonomy Colors."
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/carstingaxion/gatherpress-taxonomy-colors",
        "ref": "HEAD"
      },
      "options": {
        "activate": true
      },
      "progress": {
        "caption": "Installing plugin from GitHub: carstingaxion/gatherpress-taxonomy-colors"
      }
    },
		{
			"step": "writeFile",
			"path": "/tmp/demo-data.php",
			"data": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/carstingaxion/gatherpress-taxonomy-colors/main/.wordpress-org/blueprints/demo-data.php"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require '/tmp/demo-data.php';"
		}
	]
}
