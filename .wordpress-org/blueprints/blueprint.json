{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/wp-admin/post.php?post=10&action=edit",
	"preferredVersions": {
		"php": "8.3",
		"wp": "latest"
	},
	"login": true,
	"steps": [
		{
		"step": "setSiteOptions",
		"options": {
			"blogname": "GatherPress Taxonomy Colors",
			"blogdescription": "Enhancing GatherPress with Taxonomy Colors."
		}
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/GatherPress/gatherpress/releases/download/0.34.0-beta.2/gatherpress.0.34.0-beta.2.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/carstingaxion/gatherpress-taxonomy-colors/releases/latest/download/gatherpress-taxonomy-colors.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "writeFile",
			"path": "/tmp/demo-data.php",
			"data": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/carstingaxion/gatherpress-taxonomy-colors/main/.wordpress-org/blueprints/demo-data.php"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require '/tmp/demo-data.php';"
		}
	]
}
